# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Path to the credentials.json downloaded from Google Cloud Console
# Leave blank if credentials.json is in the project root
GMAIL_CREDENTIALS_PATH=credentials.json

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Examples:
#   Local:  postgresql://postgres:password@localhost:5432/emaildb
#   Remote: postgresql://user:pass@your-host.com:5432/emaildb
#   Render / Railway / Supabase → copy the connection string from their dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname
